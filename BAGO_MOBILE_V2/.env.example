# Bago Mobile — environment variable template
# Copy to .env and fill in your values.
# EXPO_PUBLIC_* variables are bundled into the app.
# NEVER put secret keys, JWT secrets, or DB credentials here.

# ── API ──────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://your-backend.onrender.com

# ── Payment Gateways (publishable/public keys only) ──────────────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# ── Google OAuth (public client IDs only — NOT the client secret) ─────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_project.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client.apps.googleusercontent.com

# ── Expo ─────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_EXPO_PROJECT_ID=your_expo_project_id
