# Bago Platform - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ================================
# SERVER CONFIGURATION
# ================================
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ================================
# SECURITY
# ================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ADMIN_SECRET_KEY=your_admin_secret_key_change_this

# ================================
# DATABASE
# ================================
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/bago

# MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bago?retryWrites=true&w=majority

# ================================
# SUPABASE
# ================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ================================
# EMAIL SERVICE (RESEND)
# ================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# ================================
# IMAGE UPLOAD (CLOUDINARY)
# ================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ================================
# PAYMENT PROCESSORS
# ================================

# Stripe (Global Payments)
# Get your key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Paystack (African Payments)
# Get your key from: https://dashboard.paystack.com/settings/developer
PAYSTACK_SECRET=sk_test_your_paystack_secret_key

# ================================
# KYC VERIFICATION (DIDIT.ME)
# ================================
# Get credentials from: https://didit.me/dashboard
DIDIT_API_KEY=your_didit_api_key
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret

# ================================
# GOOGLE OAUTH
# ================================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_PROJECT_ID=your_project_id

# ================================
# OPTIONAL SERVICES
# ================================

# Push Notifications (APNs for native iOS tokens)
# Use the App Store / production host by default. Set APNS_USE_SANDBOX=true
# when testing against the Apple sandbox environment.
APNS_BUNDLE_ID=com.deracali.boltexponativewind
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_KEY_ID=YOUR_APNS_KEY_ID
# Either paste the full .p8 content here with \n escaped, or set APNS_PRIVATE_KEY_PATH.
APNS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# APNS_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXX.p8
# APNS_USE_SANDBOX=true

# Sentry (Error Tracking)
# SENTRY_DSN=your_sentry_dsn

# Mixpanel (Analytics)
# MIXPANEL_TOKEN=your_mixpanel_token

# Redis (Caching)
# REDIS_URL=redis://localhost:6379
